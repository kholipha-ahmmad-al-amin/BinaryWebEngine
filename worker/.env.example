# ─── Required (set via `wrangler secret put`) ───────────────────────────────
# NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Optional (also configurable via Settings > API Keys in dashboard) ─────
# IPINFO_TOKEN=your_ipinfo_token
# ABUSEIPDB_KEY=your_abuseipdb_key
# VIRUSTOTAL_KEY=your_virustotal_key

# ─── Worker Domain ─────────────────────────────────────────────────────────
# After first deploy, update API_BASE in frontend/app.js to your Worker URL:
# const API = 'https://bwe-api.YOUR_SUBDOMAIN.workers.dev';
